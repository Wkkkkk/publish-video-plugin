# publish-video configuration — copy to .env and fill in, then:
#   set -a; source .env; set +a
# (.env is gitignored; never commit real credentials.)

# --- S3-compatible object storage (Cloudflare R2) ---
# Uploads go here (authenticated S3 API endpoint, account-scoped):
PUBLISH_VIDEO_S3_ENDPOINT=https://<ACCOUNT_ID>.r2.cloudflarestorage.com
PUBLISH_VIDEO_S3_BUCKET=mytv-vod
# Browsers READ from here (the bucket's public base — r2.dev subdomain or custom domain).
# Different host from the endpoint above — do not swap them:
PUBLISH_VIDEO_PUBLIC_BASE_URL=https://pub-<hash>.r2.dev

# --- Bucket credentials (boto3 standard chain) ---
AWS_ACCESS_KEY_ID=<r2-access-key-id>
AWS_SECRET_ACCESS_KEY=<r2-secret-access-key>
# R2 quirk: boto3 may demand a region; "auto" satisfies it.
AWS_DEFAULT_REGION=auto

# --- MyTV sink (only needed for --sink mytv) ---
#MYTV_BASE_URL=https://kunstv.fly.dev
#MYTV_ADMIN_PASSWORD=<admin-password>

# --- video-summarizer (only needed for the [[post_run]] summarize action) ---
# The video-summarizer CLI reads these from the environment; folding them in here
# means the watcher's `source .env` exports them too (no second .env to source).
# GEMINI_API_KEY drives the default backend; set ANTHROPIC_API_KEY instead (and
# summary_backend = "claude" in watcher.toml) to summarize with Claude.
#GEMINI_API_KEY=<gemini-api-key>
#ANTHROPIC_API_KEY=<anthropic-api-key>
